{erl_opts, [debug_info, warnings_as_errors]}.
{minimum_otp_vsn, "28"}.

{deps, []}.

{dialyzer, [
    {warnings, [unmatched_returns, error_handling, underspecs]},
    {plt_extra_apps, []}
]}.

{profiles, [
    {test, [
        {erl_opts, [nowarn_export_all]},
        {deps, [
            {assert, {git, "https://github.com/WhatsApp/assert.git", {branch, "main"}}},
            {proper, "1.4.0"}
        ]},
        {extra_src_dirs, ["test"]}
    ]},
    {prod, [
        {relx, [
            {mode, prod},
            {include_erts, true},
            {debug_info, strip}
        ]}
    ]}
]}.

{eunit_opts, [verbose]}.

{project_plugins, [
    erlfmt,
    rebar3_ex_doc
]}.

{erlfmt, [write]}.

{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used,
    deprecated_function_calls
]}.

%% Elixir DSL module is optional — only available when the Elixir DSL app is loaded.
{xref_ignores, [
    {'Elixir.ErlkoenigEbpfDsl', compile_debug_string, 1}
]}.

{relx, [
    {release, {erlkoenig_ebpf, "0.1.0"}, [erlkoenig_ebpf]},
    {mode, minimal},
    {extended_start_script, true},
    {include_src, false}
]}.
